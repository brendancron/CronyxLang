import "../../../stdlib/collections/List";
import "../../../stdlib/lang/Option";

var nums = [1, 2, 3, 4, 5];

var doubled = List.map(nums) { it * 2 };
print(doubled[0]);
print(doubled[4]);

var sum = List.fold(nums, 0, fn(acc, x) { return acc + x; });
print(sum);

print(List.any(nums) { it > 4 });
print(List.all(nums) { it > 0 });

var rev = List.reverse(nums);
print(rev[0]);
print(rev[4]);

var words = ["hello", "world"];
print(List.join(words, ", "));

var big = List.filter(nums) { it > 3 };
print(big[0]);
print(big[1]);

var found = List.find(nums) { it > 3 };
match found {
    Option::Some(v) => { print(v); }
    Option::None    => { print("none"); }
}

var a = [1, 2];
var b = [3, 4];
var c = List.concat(a, b);
print(c[0]);
print(c[3]);

var flat = List.flat_map([[1, 2], [3, 4]], fn(xs) { return xs; });
print(flat[0]);
print(flat[3]);
