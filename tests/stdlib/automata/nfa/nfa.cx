import "../../../../stdlib/automata/Nfa";

// Test 1: accepts exactly [42]
var nfa1 = Nfa.nfa_new(0);
nfa1.add_state(1);
nfa1.add_symbol(42);
nfa1.add_transition(0, 42, 1);
nfa1.add_accept(1);
print(nfa1.accepts([42]));      // true
print(nfa1.accepts([]));         // false
print(nfa1.accepts([1]));       // false
print(nfa1.accepts([42, 42]));  // false

// Test 2: epsilon transition (0 -ε-> 1 -42-> 2)
var nfa2 = Nfa.nfa_new(0);
nfa2.add_state(1);
nfa2.add_state(2);
nfa2.add_symbol(42);
nfa2.add_epsilon(0, 1);
nfa2.add_transition(1, 42, 2);
nfa2.add_accept(2);
print(nfa2.accepts([42]));   // true
print(nfa2.accepts([]));      // false

// Test 3: alternation — accepts [1] or [2]
var nfa3 = Nfa.nfa_new(0);
nfa3.add_state(1);
nfa3.add_state(2);
nfa3.add_symbol(1);
nfa3.add_symbol(2);
nfa3.add_transition(0, 1, 1);
nfa3.add_transition(0, 2, 2);
nfa3.add_accept(1);
nfa3.add_accept(2);
print(nfa3.accepts([1]));      // true
print(nfa3.accepts([2]));      // true
print(nfa3.accepts([3]));      // false
print(nfa3.accepts([1, 2]));   // false
print(nfa3.accepts([]));        // false

// Test 4: kleene star — zero or more 1s
var nfa4 = Nfa.nfa_new(0);
nfa4.add_symbol(1);
nfa4.add_transition(0, 1, 0);
nfa4.add_accept(0);
print(nfa4.accepts([]));           // true
print(nfa4.accepts([1]));         // true
print(nfa4.accepts([1, 1, 1]));   // true
print(nfa4.accepts([2]));         // false

// Test 5: concatenation — accepts [1, 2]
var nfa5 = Nfa.nfa_new(0);
nfa5.add_state(1);
nfa5.add_state(2);
nfa5.add_symbol(1);
nfa5.add_symbol(2);
nfa5.add_transition(0, 1, 1);
nfa5.add_transition(1, 2, 2);
nfa5.add_accept(2);
print(nfa5.accepts([1, 2]));   // true
print(nfa5.accepts([1]));       // false
print(nfa5.accepts([2]));       // false
print(nfa5.accepts([]));         // false
print(nfa5.accepts([2, 1]));   // false

// Test 6: epsilon chain (0 -ε-> 1 -ε-> 2, accept = {2})
var nfa6 = Nfa.nfa_new(0);
nfa6.add_state(1);
nfa6.add_state(2);
nfa6.add_epsilon(0, 1);
nfa6.add_epsilon(1, 2);
nfa6.add_accept(2);
print(nfa6.accepts([]));   // true — start reaches accept via epsilon chain
