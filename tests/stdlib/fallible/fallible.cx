import "../../../stdlib/lang/Fallible";

fn parse_int(s) {
    if (s == "42") {
        return 42;
    }
    return raise("not a number: " + s);
}

run {
    var n = parse_int("42");
    print(n);
} handle Fallible {
    fn raise(msg) {
        print("fallible: " + msg);
        return -1;
    }
}

run {
    var n = parse_int("abc");
    print(n);
} handle Fallible {
    fn raise(msg) {
        print("fallible: " + msg);
        return -1;
    }
}
