// GADTs: each constructor pins the type parameter to a concrete type.
// The type checker refines T in each match arm, making eval total and cast-free.

enum Expr<T> {
    Lit(int)                            : Expr<int>,
    Add(Expr<int>, Expr<int>)           : Expr<int>,
    BoolLit(bool)                       : Expr<bool>,
    If<A>(Expr<bool>, Expr<A>, Expr<A>) : Expr<A>,
    Pair<A, B>(Expr<A>, Expr<B>)        : Expr<(A, B)>,
    Fst<A, B>(Expr<(A, B)>)             : Expr<A>,
}

fn eval<T>(e: Expr<T>): T {
    match e {
        Expr::Lit(n)      => n,
        Expr::Add(l, r)   => eval(l) + eval(r),
        Expr::BoolLit(b)  => b,
        Expr::If(c, t, f) => { if (eval(c)) { return eval(t); } else { return eval(f); } }
        Expr::Pair(a, b)  => (eval(a), eval(b)),
        Expr::Fst(p)      => eval(p).0,
    }
}

print(eval(Expr::Add(Expr::Lit(40), Expr::Lit(2))));
print(eval(Expr::If(Expr::BoolLit(true), Expr::Lit(1), Expr::Lit(0))));

// Length-indexed list: head() is statically safe — Nil cannot reach it.

struct Zero {}
struct Succ<N> {}

enum Vec<N, T> {
    Nil<T>               : Vec<Zero, T>,
    Cons<N, T>(T, Vec<N, T>) : Vec<Succ<N>, T>,
}

fn head<N, T>(v: Vec<Succ<N>, T>): T {
    match v {
        Vec::Cons(x, _) => x,
    }
}

var one = Vec::Cons(10, Vec::Nil);
var two = Vec::Cons(20, Vec::Cons(10, Vec::Nil));

print(head(two));
print(head(one));
