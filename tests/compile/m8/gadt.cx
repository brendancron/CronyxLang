enum Expr<T> {
    Lit(int)              : Expr<int>,
    Add(Expr<int>, Expr<int>) : Expr<int>,
    BoolLit(bool)         : Expr<bool>,
}

fn eval_int(e: Expr<int>): int {
    match e {
        Expr::Lit(n)    => n,
        Expr::Add(l, r) => eval_int(l) + eval_int(r),
    }
}

print(eval_int(Expr::Lit(42)));
print(eval_int(Expr::Add(Expr::Lit(10), Expr::Lit(32))));
