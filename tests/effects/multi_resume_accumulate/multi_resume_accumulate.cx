// Phase 4: Multi-resume with more complex branching.
// Each flip() creates a choice point; two flips create 4 branches.

effect flip {
    ctl flip(): bool;
}

with ctl flip(): bool {
    resume true;
    resume false;
}

var a = flip();
var b = flip();

if (a && b) {
    print("TT");
} else if (a && !b) {
    print("TF");
} else if (!a && b) {
    print("FT");
} else {
    print("FF");
}
