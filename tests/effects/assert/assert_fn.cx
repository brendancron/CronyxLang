effect ndet {
    ctl choose(options): int;
    ctl assert(cond): unit;
}

with ctl choose(options): int {
    for (x in options) {
        resume x;
    }
}

with ctl assert(cond): unit {
    if (cond) {
        resume;
    }
}

fn find_matching(list1, list2) {
    var choice1 = choose(list1);
    var choice2 = choose(list2);
    assert(choice1 == choice2);
    return(choice1);
}

var result = find_matching([1,2,3,4,5], [3,5,7]);

print(result);
