// Phase 3: Inner handler shadows outer handler for same operation.
// Tests that handler stack lookup finds the most recently installed handler.

effect yield {
    ctl yield(i: int): unit;
}

with ctl yield(i: int): unit {
    print("outer: " + to_string(i));
    resume
}

yield(1);

with ctl yield(i: int): unit {
    print("inner: " + to_string(i));
    resume
}

yield(2);
