// Phase 3: Handler that doesn't call resume — aborts the continuation.
// After abort(msg), the rest of the computation should NOT execute.

effect abort {
    ctl abort(msg: string): unit;
}

with ctl abort(msg: string): unit {
    print("aborted: " + msg);
    // no resume — continuation is discarded
}

print("before");
abort("something went wrong");
print("after");
