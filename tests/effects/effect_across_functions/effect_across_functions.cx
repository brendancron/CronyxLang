// Phase 3: Effect operations work across function call boundaries.
// Handler is installed in caller, effect is performed in callee.

effect yield {
    ctl yield(i: int): unit;
}

fn count_up(n: int) {
    for (var i = 0; i < n; i += 1) {
        yield(i);
    }
}

with ctl yield(i: int): unit {
    print(i * 100);
    resume
}

count_up(3);
