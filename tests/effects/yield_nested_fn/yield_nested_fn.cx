// Phase 3: yield from inside a called function.
// Tests that ctl effects propagate through function call boundaries.

effect yield {
    ctl yield(i: int): unit;
}

fn emit_pair(a: int, b: int) {
    yield(a);
    yield(b);
}

with ctl yield(i: int): unit {
    print(i);
    resume
}

emit_pair(10, 20);
