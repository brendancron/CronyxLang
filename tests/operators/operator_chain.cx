struct Vec2 {
    x: int;
    y: int
}

impl Add for Vec2 {
    fn add(a: Vec2, b: Vec2): Vec2 {
        return Vec2 { x: a.x + b.x, y: a.y + b.y };
    }
}

var v1 = Vec2 { x: 1, y: 1 };
var v2 = Vec2 { x: 1, y: 1 };
var v3 = Vec2 { x: 1, y: 1 };
var result = v1 + v2 + v3;
print(result.x);
print(result.y);
